---
interface Props {
  quote: {
    id: number
    quote: string
  }
}
const { quote: data } = Astro.props
---

<quote>"{data.quote}"</quote>

<style>
  div {
    display: flex;
  }

  quote {
    font-size: 1rem;
    border: 2px solid var(--bento-border-color);
    border-radius: var(--border-radius);
    margin: 1rem 0.5rem;
    width: 250px;
    display: block;
    flex: 2 2 250px;
    padding: 1rem;
  }
</style>
